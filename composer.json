{
  "name": "mblsolutions/simfoni-php-laravel",
  "description": "Official Simfoni interface for Laravel PHP applications.",
  "keywords": ["simfoni", "giftcard", "e-gift", "laravel"],
  "type": "package",
  "license": "MIT",
  "authors": [
    {
      "name": "MBL Solutions Ltd",
      "email": "support@mblsolutions.co.uk"
    }
  ],
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "illuminate/events": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/session": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/pagination": "^10.0|^11.0|^12.0|^13.0",
    "mblsolutions/simfoni-php": "^3.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0",
    "phpunit/phpunit": "^8.0|^9.3|^11.0"
  },
  "autoload": {
    "psr-4": {
      "MBLSolutions\\SimfoniLaravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MBLSolutions\\SimfoniLaravel\\Tests\\": "tests"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "extra": {
    "laravel": {
      "providers": [
        "MBLSolutions\\SimfoniLaravel\\SimfoniServiceProvider"
      ]
    }
  }
}
